---
import BaseLayout from "../layouts/BaseLayout.astro";
import Features from "../components/widgets/Features.astro";
import Content from "../components/widgets/Content.astro";
import Form from "../components/ui/Form.astro";

const metadata = {
  title: "Contact",
  description: "Get in touch with Abhishek to discuss your next project.",
};

const visionText = ["Get in touch to discuss your next project."];
---

<BaseLayout {metadata}>
  <Content tagline="Contact" title="Contact" description={visionText} />
  <div
    class="reveal mx-auto max-w-xl bg-card border border-border rounded-3xl p-8 shadow-sm mb-12 md:mb-16"
  >
    <Form />
  </div>
  <Features
    tagline="Contact"
    title="Let's talk"
    subtitle="I typically respond within 24 hours."
    classes={{ container: "pt-0 md:pt-0" }}
    features={[
      {
        title: "Email",
        description: "hello@abyshakes.com",
        icon: "lucide:mail",
        iconClass: "bg-yellow-500/10 text-yellow-400",
      },
      {
        title: "Location",
        description: "Panjim, Goa, India",
        icon: "lucide:map-pin",
        iconClass: "bg-red-500/10 text-red-400",
      },
      {
        title: "X (Twitter)",
        description: "@abyshakes",
        icon: "lucide:twitter",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "GitHub",
        description: "github.com/abyshakes",
        icon: "lucide:github",
        iconClass: "bg-green-500/10 text-green-400",
      },
      {
        title: "LinkedIn",
        description: "linkedin.com/in/abhishekprabhu",
        icon: "lucide:linkedin",
        iconClass: "bg-indigo-500/10 text-indigo-400",
      },
      {
        title: "Available for",
        description: "Freelance projects, consulting engagements, and technical leadership roles.",
        icon: "lucide:briefcase",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
    ]}
  />
</BaseLayout>
