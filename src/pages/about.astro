---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getImage } from "astro:assets";
import Content2 from "../components/widgets/Content2.astro";
import Values from "../components/widgets/Values.astro";
import aboutImage from "../assets/images/about-office.webp";

const metadata = {
  title: "About",
  description:
    "Abhishek Prabhu — full-stack web consultant with 24 years of experience in design and development.",
};

const values = [
  {
    title: "Functionality first",
    description:
      "Features that don't work reliably aren't features. I build for correctness before anything else.",
  },
  {
    title: "Performance matters",
    description:
      "Slow software costs real money. I profile, measure, and optimize rather than guess.",
  },
  {
    title: "Long-term maintainability",
    description:
      "Code is read far more than it is written. I write for the next developer, often my future self.",
  },
  {
    title: "Design thinking",
    description:
      "I started in design and apply those principles to architecture, APIs, and code readability.",
  },
  {
    title: "Honest communication",
    description:
      "Clear, direct feedback at every stage. No surprises, no over-promising.",
  },
  {
    title: "Continuous improvement",
    description:
      "Technology moves fast. I stay current so the systems I build don't become tomorrow's legacy problem.",
  },
];

const optimizedImage = await getImage({
  src: aboutImage,
  format: "webp",
});
---

<BaseLayout {metadata}>
  <link slot="head" rel="preload" href={optimizedImage.src} as="image" />
  <Content2
    title="Hi, I'm Abhishek"
    description={[
      "I'm a full-stack web consultant based in Panjim, Goa with 24 years of experience in design and development. My work sits at the intersection of brand thinking and engineering — I care deeply about how things look, but I'll never trade correctness or performance for aesthetics.",
      "I started in design, which gave me an eye for the user side of software. Over the years I've moved deeper into the stack — backend systems, databases, DevOps — while keeping that design sensibility in the way I structure code and architect systems. Since 2016 I've been freelancing full-time, leading small engineering teams across education, e-commerce, ERP, and hospitality.",
    ]}
    tagline="About"
    image={aboutImage}
    imageAlt="Abhishek Prabhu — full-stack web consultant"
    actions={[
      {
        text: "Get in Touch",
        href: "/contact",
        variant: "primary",
        icon: "lucide:mail",
      },
      {
        text: "My Services",
        href: "/services",
        variant: "secondary",
        icon: "lucide:arrow-right",
      },
    ]}
  />
  <Values
    items={values}
    columns={3}
    tagline="My Values"
    title="What Drives My Work"
    subtitle="Principles I apply to every project, large or small"
  />
</BaseLayout>
