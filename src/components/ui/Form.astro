---
import Button from "./Button.astro";

interface Props {
  action?: string;
  method?: "GET" | "POST";
}

const { action = "#", method = "POST" } = Astro.props;
---

<form id="contact-form" class="space-y-6">
  <div>
    <label for="name" class="block text-sm font-medium text-foreground/80 mb-2"
      >Name</label
    >
    <input
      type="text"
      name="name"
      id="name"
      autocomplete="name"
      required
      class="block w-full rounded-xl border-border bg-muted/50 px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-primary/20 transition-all border outline-none focus:ring-4"
      placeholder="Your name"
    />
  </div>
  <div>
    <label for="email" class="block text-sm font-medium text-foreground/80 mb-2"
      >Email</label
    >
    <input
      type="email"
      name="email"
      id="email"
      autocomplete="email"
      required
      class="block w-full rounded-xl border-border bg-muted/50 px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-primary/20 transition-all border outline-none focus:ring-4"
      placeholder="your@email.com"
    />
  </div>
  <div>
    <label
      for="message"
      class="block text-sm font-medium text-foreground/80 mb-2">Message</label
    >
    <textarea
      name="message"
      id="message"
      rows="4"
      required
      class="block w-full rounded-xl border-border bg-muted/50 px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-primary/20 transition-all border outline-none focus:ring-4 resize-none"
      placeholder="How can we help you?"></textarea>
  </div>
  <div id="status-message" class="hidden rounded-lg p-4"></div>
  <div>
    <Button id="submit-btn" type="submit" size="lg" class="w-full sm:w-auto">
      Send message
    </Button>
  </div>
</form>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const statusMessage = document.getElementById(
    "status-message"
  ) as HTMLDivElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const name = (document.getElementById("name") as HTMLInputElement).value;
    const email = (document.getElementById("email") as HTMLInputElement).value;
    const message = (document.getElementById("message") as HTMLTextAreaElement)
      .value;

    // Disable button while sending
    submitBtn.disabled = true;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = "Sending...";

    // Clear previous messages
    statusMessage.classList.add("hidden");
    statusMessage.textContent = "";

    try {
      const response = await fetch("/api/contact", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ name, email, message }),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        // Show success message
        statusMessage.classList.remove("hidden");
        statusMessage.classList.add(
          "bg-green-500/10",
          "border",
          "border-green-500/20",
          "text-green-700",
          "dark:text-green-300"
        );
        statusMessage.innerHTML =
          "<strong>Success!</strong> Your message has been sent. I'll get back to you soon.";

        // Reset form
        form.reset();
      } else {
        // Show error message
        statusMessage.classList.remove("hidden");
        statusMessage.classList.add(
          "bg-red-500/10",
          "border",
          "border-red-500/20",
          "text-red-700",
          "dark:text-red-300"
        );
        statusMessage.innerHTML =
          `<strong>Error!</strong> ${result.error || "Something went wrong. Please try again."}`;
      }
    } catch (error) {
      // Show network error
      statusMessage.classList.remove("hidden");
      statusMessage.classList.add(
        "bg-red-500/10",
        "border",
        "border-red-500/20",
        "text-red-700",
        "dark:text-red-300"
      );
      statusMessage.innerHTML =
        "<strong>Error!</strong> Failed to send message. Please check your connection and try again.";
      console.error("Form submission error:", error);
    } finally {
      // Re-enable button
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
