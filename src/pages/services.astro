---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceList from "../components/widgets/ServiceList.astro";
import Content from "../components/widgets/Content.astro";
import Content2 from "../components/widgets/Content2.astro";
import webDevImg from "../assets/images/services/web-dev.webp";
import seoImg from "../assets/images/services/seo.webp";
import consultingImg from "../assets/images/services/consulting.webp";

const services = [
  {
    title: "Website Development",
    description:
      "Custom websites and web applications built to perform — from portfolio sites and blogs to membership platforms and e-commerce stores.",
    icon: "lucide:monitor",
    href: "/website-development",
  },
  {
    title: "Automation & AI Workflows",
    description:
      "Business processes streamlined or fully automated — internal tools, agentic AI workflows, and AI-powered chat on WhatsApp.",
    icon: "lucide:bot",
  },
  {
    title: "DevOps & Infrastructure",
    description:
      "Reliable hosting, deployment pipelines, Docker, Linux servers, Cloudflare, and CI/CD — infrastructure that keeps your platform fast, secure, and always on.",
    icon: "lucide:server",
  },
];
const metadata = {
  title: "Services",
  description:
    "Website development, business automation, AI workflows, and DevOps infrastructure — built with 24 years of experience.",
};
---

<BaseLayout {metadata}>
  <Content
    tagline="Services"
    title="What I Offer"
    description={[
      "Three focused areas of work — websites that last, automation that saves time, and infrastructure that doesn't let you down.",
    ]}
  />
  <ServiceList services={services} classes={{ container: "pt-0 md:pt-0" }} />
  <Content2
    items={[
      {
        title: "Brochure & Portfolio Sites",
        description:
          "Clean, fast, and professionally designed sites that represent your brand and convert visitors.",
      },
      {
        title: "E-commerce & Membership",
        description:
          "Online stores, subscription platforms, and gated content — built to handle real transaction volume.",
      },
      {
        title: "Custom Web Applications",
        description:
          "Bespoke platforms and internal tools when off-the-shelf software doesn't cut it.",
      },
    ]}
    image={webDevImg}
    imageAlt="Website development"
    actions={[
      {
        text: "View Plans & Pricing",
        href: "/website-development",
        variant: "primary",
        icon: "lucide:arrow-right",
      },
    ]}
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Website Development
      </h3>
      Every site I build is custom — no bloated templates, no unnecessary dependencies.
      From a one-page portfolio to a full e-commerce platform, the goal is always the same:
      fast, maintainable, and built to grow with you.
    </Fragment>
  </Content2>

  <Content2
    isReversed={true}
    items={[
      {
        title: "Business Process Automation",
        description:
          "Eliminate repetitive manual work — approvals, notifications, data entry, reporting — with reliable automated workflows.",
      },
      {
        title: "Agentic AI Workflows",
        description:
          "AI agents that handle multi-step tasks autonomously, from lead qualification to content generation and data processing.",
      },
      {
        title: "AI Chat on WhatsApp",
        description:
          "Intelligent, always-on WhatsApp bots that answer questions, qualify leads, and handle customer interactions around the clock.",
      },
    ]}
    image={seoImg}
    imageAlt="Automation and AI workflows"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Automation & AI Workflows
      </h3>
      If your team is doing the same thing more than twice, it can probably be automated.
      I identify the friction points in your business and build systems — from simple scripts
      to full agentic AI pipelines — that remove them.
    </Fragment>
  </Content2>

  <Content2
    items={[
      {
        title: "Infrastructure as Code",
        description:
          "Docker-based environments, repeatable deployments, and zero-surprise production setups.",
      },
      {
        title: "CI/CD & Observability",
        description:
          "Automated pipelines, health checks, and alerting so problems surface before your clients do.",
      },
      {
        title: "Security & Performance",
        description:
          "Linux server hardening, Cloudflare configuration, caching strategies, and load optimisation.",
      },
    ]}
    image={consultingImg}
    imageAlt="DevOps and infrastructure"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        DevOps & Infrastructure
      </h3>
      Good software deserves a solid foundation. I handle the ops layer — hosting, deployments,
      security, and monitoring — so your platform stays fast, safe, and available without
      you having to think about it.
    </Fragment>
  </Content2>
</BaseLayout>
