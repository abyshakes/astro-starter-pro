---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
import Hero from "../components/widgets/Hero.astro";
import Features from "../components/widgets/Features.astro";
import devImg from "../assets/images/dev_balanced.png";
import openSourceImg from "../assets/images/open-source.png";
import Content2 from "../components/widgets/Content2.astro";
const metadata = {
  title: `${siteConfig.name} — Full-Stack Web Consultant`,
  description:
    "Full-stack web consultant with 24 years of experience in design and development. Sitting at the intersection of brand thinking and engineering.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <Hero
    title={`I design and build web platforms <br class="hidden md:block" /> <span class="bg-linear-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">with long-term thinking.</span>`}
    tagline="Abhishek Prabhu · Panjim, Goa"
    description="Twenty four years working between brand strategy and engineering has taught me that the best systems are simple, fast, and built to endure."
    actions={[
      {
        text: "Get in Touch",
        href: "/contact",
        variant: "primary",
        icon: "lucide:mail",
      },
      {
        text: "My Services",
        href: "/services",
        variant: "secondary",
        icon: "lucide:arrow-right",
        ariaLabel: "Learn more about my services",
      },
    ]}
  >
    <a
      slot="extra-actions"
      href="https://wa.me/919821798216"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contact via WhatsApp"
      class="inline-flex items-center justify-center gap-2 w-full sm:w-auto rounded-xl px-8 py-4 text-lg font-bold text-white transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#25D366] transform hover:scale-105 shadow-lg"
      style="background-color: #25D366; hover:background-color: #1ebe57;"
      onmouseover="this.style.backgroundColor='#1ebe57'"
      onmouseout="this.style.backgroundColor='#25D366'"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        width="22"
        height="22"
        fill="white"
        aria-hidden="true"
        class="shrink-0"
      >
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Contact via WhatsApp
    </a>
  </Hero>
  <Features
    tagline="Expertise"
    title="What I Do"
    subtitle="End-to-end web consulting across the full stack — from architecture to deployment."
    features={[
      {
        title: "Backend Development",
        description:
        "Laravel, PHP, WordPress, TypeScript, Node.js, MySQL, PostgreSQL, Redis.",
        icon: "lucide:server",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Frontend Development",
        description: "Vue.js, Inertia.js, Tailwind CSS, React.",
        icon: "lucide:monitor",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "DevOps & Infrastructure",
        description: "Docker, Linux, Git, CI/CD, Cloudflare.",
        icon: "lucide:cloud",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
    ]}
  />
  <Content2
    items={[
      {
        title: "SaaS Architecture",
        description:
          "Designing multi-tenant systems built to scale from day one.",
        icon: "lucide:layers",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Legacy Modernization",
        description: "Safely migrating and refactoring ageing codebases.",
        icon: "lucide:refresh-cw",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "Performance Optimization",
        description: "Profiling, caching, and tuning for real-world load.",
        icon: "lucide:zap",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
    ]}
    image={devImg}
    imageAlt="Full-stack development"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Engineering with intention
      </h3>
      I began in design and carry those principles into software architecture and
      code readability. The result is systems that are a pleasure to build on.
    </Fragment>
  </Content2>
  <Content2
    items={[
      {
        title: "Team Leadership",
        description:
          "Leading 3–6 person engineering teams across education, e-commerce, ERP, and hospitality.",
        icon: "lucide:users",
        iconClass: "bg-indigo-500/10 text-indigo-400",
      },
      {
        title: "High Retention",
        description:
          "~80% client retention through clear communication and consistent delivery.",
        icon: "lucide:handshake",
        iconClass: "bg-orange-500/10 text-orange-400",
      },
      {
        title: "Agile Delivery",
        description:
          "Iterative, transparent delivery with a focus on long-term maintainability.",
        icon: "lucide:iteration-cw",
        iconClass: "bg-teal-500/10 text-teal-400",
      },
    ]}
    image={openSourceImg}
    imageAlt="Consulting and leadership"
    isReversed={true}
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Consulting that sticks
      </h3>
      Freelance full-stack consultant since 2016. I work closely with clients to
      understand their domain and deliver solutions that outlast the engagement.
    </Fragment>
  </Content2>
  <Content2
    items={[
      {
        title: "Claude Code",
        description:
          "Using Anthropic's AI CLI as an always-on pair programmer — from architecture decisions to debugging and refactoring.",
        icon: "lucide:bot",
        iconClass: "bg-violet-500/10 text-violet-400",
      },
      {
        title: "Accelerated Delivery",
        description:
          "AI handles boilerplate and repetition; I focus on design, edge cases, and the hard decisions that matter.",
        icon: "lucide:zap",
        iconClass: "bg-amber-500/10 text-amber-400",
      },
      {
        title: "Rigorous Review",
        description:
          "Every AI-generated suggestion is read, understood, and tested before it ships — quality and ownership stay mine.",
        icon: "lucide:shield-check",
        iconClass: "bg-emerald-500/10 text-emerald-400",
      },
    ]},
    image={openSourceImg}
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        AI-augmented development
      </h3>
      I've integrated AI tools — particularly Claude Code — into my daily workflow.
      It means faster iteration and fewer context-switches, while keeping the same
      standard of craft I'd apply without it.
    </Fragment>
  </Content2>
</BaseLayout>
