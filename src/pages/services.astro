---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceList from "../components/widgets/ServiceList.astro";
import Content from "../components/widgets/Content.astro";
import Content2 from "../components/widgets/Content2.astro";
import webDevImg from "../assets/images/services/web-dev.webp";
import seoImg from "../assets/images/services/seo.webp";
import consultingImg from "../assets/images/services/consulting.webp";

const services = [
  {
    title: "Full-Stack Development",
    description:
      "End-to-end web application development with Laravel, Vue.js, TypeScript, and modern tooling.",
    icon: "lucide:code-2",
  },
  {
    title: "SaaS Architecture",
    description:
      "Designing scalable, multi-tenant systems with the right trade-offs from the start.",
    icon: "lucide:layers",
  },
  {
    title: "Legacy Modernization",
    description:
      "Safely migrating and refactoring ageing PHP/WordPress/Drupal codebases.",
    icon: "lucide:refresh-cw",
  },
  {
    title: "Performance Optimization",
    description:
      "Profiling, query optimization, caching strategies, and infrastructure tuning.",
    icon: "lucide:zap",
  },
  {
    title: "Technical Leadership",
    description:
      "Leading and mentoring small engineering teams through complex delivery.",
    icon: "lucide:users",
  },
  {
    title: "DevOps & Infrastructure",
    description:
      "Docker, Linux server management, CI/CD pipelines, and Cloudflare configuration.",
    icon: "lucide:server",
  },
];
const metadata = {
  title: "Services",
  description:
    "Full-stack development, SaaS architecture, legacy modernization, performance optimization, and technical leadership.",
};
---

<BaseLayout {metadata}>
  <Content
    tagline="Services"
    title="What I Offer"
    description={[
      "Hands-on consulting across the full stack — from greenfield architecture to rescuing troubled projects.",
    ]}
  />
  <ServiceList services={services} classes={{ container: "pt-0 md:pt-0" }} />
  <Content
    tagline="Full-Stack Development"
    title="Building for the long run"
    description={[
      "I specialize in Laravel, Vue.js, TypeScript, and Node.js — choosing the right tool for the problem rather than defaulting to the fashionable one.",
    ]}
    classes={{ container: "pb-0 md:pb-0" }}
  />
  <Content2
    items={[
      {
        title: "Laravel & PHP",
        description:
          "Production-grade APIs, multi-tenant SaaS platforms, and complex business logic.",
      },
      {
        title: "Vue.js & Inertia.js",
        description:
          "Reactive frontends with a tight server-side integration and minimal overhead.",
      },
    ]}
    image={webDevImg}
    imageAlt="Full-stack web development"
    classes={{ container: "pt-0 md:pt-0" }}
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Full-Stack Development
      </h3>
      End-to-end ownership of features — from database schema to UI interaction.
      I build systems that are a pleasure to work in and easy to hand over.
    </Fragment>
  </Content2>

  <Content2
    isReversed={true}
    items={[
      {
        title: "Audit & assessment",
        description:
          "Deep analysis of existing codebases to surface risks, bottlenecks, and quick wins.",
      },
      {
        title: "Incremental migration",
        description:
          "Modernizing legacy systems without stopping the business — step by step.",
      },
    ]}
    image={seoImg}
    imageAlt="Legacy modernization"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Legacy Modernization
      </h3>
      Old codebases don't have to stay that way. I've helped teams migrate from WordPress,
      Drupal, and ageing PHP to maintainable modern stacks without losing momentum.
    </Fragment>
  </Content2>

  <Content2
    items={[
      {
        title: "Infrastructure as code",
        description:
          "Docker-based environments, repeatable deployments, and zero-surprise production setups.",
      },
      {
        title: "CI/CD & observability",
        description:
          "Automated pipelines, health checks, and alerting so problems surface before clients do.",
      },
    ]}
    image={consultingImg}
    imageAlt="DevOps and infrastructure"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        DevOps & Infrastructure
      </h3>
      From Linux server hardening to Cloudflare configuration and CI/CD pipelines —
      I handle the ops layer so your team can focus on product.
    </Fragment>
  </Content2>
</BaseLayout>
